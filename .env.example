# SoccerPulse Backend - Production .env Example
#
# Deployment checklist:
# [ ] Set NODE_ENV=production
# [ ] Set SPORTMONKS_API_TOKEN
# [ ] Set ADMIN_TOKEN (protect admin/dev endpoints)
# [ ] Set DATABASE_URL for durable taps/archives (recommended)
# [ ] Confirm PORT matches host platform (Render sets this automatically)
# [ ] Keep DEBUG_SPORTMONKS unset in production
# [ ] Tune SOCCER_POLL_SECONDS / SOCCER_SLICE_SECONDS if needed

# Runtime
NODE_ENV=production
PORT=3000

# Security
ADMIN_TOKEN=replace-with-strong-random-token

# Durable persistence (Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Sportmonks integration
SPORTMONKS_API_TOKEN=replace-with-your-sportmonks-token
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football

# Match engine tuning (seconds)
SOCCER_SLICE_SECONDS=60
SOCCER_POLL_SECONDS=30

# Debug (leave empty in production)
# DEBUG_SPORTMONKS=1
